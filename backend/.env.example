# Strapi Database Configuration
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi

# Strapi Security Configuration
# Generate these with `openssl rand -base64 32` or a similar tool
JWT_SECRET=
ADMIN_JWT_SECRET=
APP_KEYS=

# Cloudflare Tunnel Token
# Get this from your Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare R2 Configuration for Strapi Uploads
# See the README for instructions on how to get these values.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
