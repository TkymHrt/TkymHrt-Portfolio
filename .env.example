# Environment variables for the Next.js Frontend

# The public URL of your Strapi API.
# This should be the URL provided by your Cloudflare Tunnel.
# Example: https://strapi.yourdomain.com
STRAPI_API_URL=

# A Strapi API Token with read-only permissions for your content types.
# You can generate this in your Strapi admin panel under:
# Settings > API Tokens > Create new API Token
STRAPI_API_TOKEN=
