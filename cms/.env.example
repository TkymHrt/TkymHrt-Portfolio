# Strapi + Postgres
POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi
POSTGRES_DB=strapi

# Strapi secrets
ADMIN_JWT_SECRET=changeme
APP_KEYS=changeme,changeme2
API_TOKEN_SALT=changeme

# Public base URL of Strapi (used in generated media URLs)
STRAPI_URL=http://localhost:1337

# Cloudflare R2 (S3 compatible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfolio-assets
# Replace <accountid> below with your actual account id
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=
